{% doc %}
  COA Anchor Navigation
  A modern navigation bar with anchor links to jump to different COA sections on the page.
{% enddoc %}

{% style %}
  .coa-nav {
    padding: 0 20px 40px;
    background-color: {{ section.settings.background_color }};
  }

  .coa-nav__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .coa-nav__card {
    background: #ffffff;
    border-radius: 16px;
    padding: 24px 32px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .coa-nav__label {
    display: block;
    text-align: center;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #666666;
    margin-bottom: 16px;
  }

  .coa-nav__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .coa-nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(80, 178, 189, 0.25);
    cursor: pointer;
  }

  .coa-nav__link:hover {
    background-color: {{ section.settings.button_hover_background_color }};
    color: {{ section.settings.button_hover_text_color }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(80, 178, 189, 0.35);
  }

  .coa-nav__link:active {
    transform: translateY(0);
  }

  .coa-nav__link svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .coa-nav {
      padding: 0 16px 32px;
    }

    .coa-nav__card {
      padding: 20px;
      border-radius: 12px;
    }

    .coa-nav__links {
      flex-direction: column;
      align-items: stretch;
    }

    .coa-nav__link {
      width: 100%;
      padding: 16px 24px;
      justify-content: center;
    }
  }
{% endstyle %}

<div class="coa-nav">
  <div class="coa-nav__container">
    <div class="coa-nav__card">
      <span class="coa-nav__label">Jump to Section</span>
      <nav class="coa-nav__links" aria-label="Jump to COA section">
        {% if section.settings.link_1_label != blank and section.settings.link_1_anchor != blank %}
          <a href="#{{ section.settings.link_1_anchor }}" class="coa-nav__link">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            {{ section.settings.link_1_label }}
          </a>
        {% endif %}
        {% if section.settings.link_2_label != blank and section.settings.link_2_anchor != blank %}
          <a href="#{{ section.settings.link_2_anchor }}" class="coa-nav__link">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            {{ section.settings.link_2_label }}
          </a>
        {% endif %}
        {% if section.settings.link_3_label != blank and section.settings.link_3_anchor != blank %}
          <a href="#{{ section.settings.link_3_anchor }}" class="coa-nav__link">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            {{ section.settings.link_3_label }}
          </a>
        {% endif %}
        {% if section.settings.link_4_label != blank and section.settings.link_4_anchor != blank %}
          <a href="#{{ section.settings.link_4_anchor }}" class="coa-nav__link">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            {{ section.settings.link_4_label }}
          </a>
        {% endif %}
        {% if section.settings.link_5_label != blank and section.settings.link_5_anchor != blank %}
          <a href="#{{ section.settings.link_5_anchor }}" class="coa-nav__link">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            {{ section.settings.link_5_label }}
          </a>
        {% endif %}
      </nav>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.coa-nav__link').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href').substring(1);
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        const headerOffset = 100;
        const elementPosition = targetElement.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
        
        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth'
        });
      }
    });
  });
</script>

